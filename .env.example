# Copy to .env and fill in. .env is gitignored; never commit real keys.

# ─── LLM ───────────────────────────────────────────────
# Backend for the ripple pipeline. Options: anthropic | openai
LLM_PROVIDER=anthropic

# Anthropic (default). Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5                  # premium/reasoning tier
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001  # tier-1 classifier

# OpenAI (only if LLM_PROVIDER=openai). Key: https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_CHEAP_MODEL=gpt-4o-mini

# ─── Quotes (spot prices, gainers) ─────────────────────
# Options: finnhub | polygon
QUOTES_PROVIDER=finnhub
# Free key: https://finnhub.io/register
FINNHUB_API_KEY=

# ─── Candles (daily closes: backtest, sparklines) ──────
# Quotes and candles resolve separately because no free tier does both well:
#   finnhub free -> real-time quotes (60/min), but candles are PAID-only
#   polygon free -> daily candles, but end-of-day and ~5 requests/min
# Recommended free setup: QUOTES_PROVIDER=finnhub + CANDLES_PROVIDER=polygon.
# Leave unset to use QUOTES_PROVIDER for candles too.
CANDLES_PROVIDER=
# Free key: https://polygon.io/dashboard/signup
POLYGON_API_KEY=
# Requests/minute your Polygon plan allows (free tier is ~5).
POLYGON_RPM=5

# ─── Scan cost controls ────────────────────────────────
# Credits are the scarcest resource — these bound what one scan can spend.
SCAN_MAX_CATALYSTS=25
SCAN_MAX_CREDITS=400

# ─── Data ──────────────────────────────────────────────
DB_PATH=./data.db

# ─── Background tasks ──────────────────────────────────
# Recurring scan, as a 5-field schedule expression. EMPTY = disabled (default),
# because scans cost credits and starting the server shouldn't bill you.
# Example: "30 13 * * 1-5" = weekdays at 13:30 (pre-market if TZ=UTC).
SCAN_SCHEDULE=
# How often to evict expired ripple-cache rows, in minutes.
CACHE_SWEEP_MINUTES=360

# ─── Price alerts ──────────────────────────────────────
# Alert when a watchlist egg's return-vs-flag moves this far (%), either
# direction. Evaluated during POST /api/prices/refresh — quote data only,
# so it costs no credits.
ALERT_THRESHOLD_PCT=10

# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# ─── Client (optional) ─────────────────────────────────
# Only set if the frontend is served from a different origin than the API.
# VITE_API_BASE=http://localhost:5000
